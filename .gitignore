# vscode
.vscode

# Intellij
*.iml
.idea

# dependencies
node_modules

# local pnpm store (sandbox-writable location)
.pnpm-store

# Don't include the compiled main.js file in the repo.
# It should be uploaded to GitHub releases instead.
main.js

# Exclude sourcemaps
*.map

# test coverage
coverage

# obsidian
data.json

# Exclude macOS Finder (System Explorer) View States
.DS_Store

# Generated database module (built from data/opdb-simplified.json.gz).
# The hand-written ambient declaration is committed so the bundled data's type
# is known when linting/type-checking a fresh checkout before the module is
# generated; the generated .ts shadows it once `generate-db` has run.
src/generated/*
!src/generated/database.d.ts
